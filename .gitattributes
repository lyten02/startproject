# Default: auto-detect text vs binary, normalize text to LF in repo
* text=auto eol=lf

# Source files — strict LF (CRLF in shebang breaks bash on Linux)
*.sh text eol=lf
*.hx text eol=lf
*.hxml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Windows-specific scripts (when present) — CRLF
*.ps1 text eol=crlf

# Binary asset guards (Heaps res/ may contain text-looking binaries)
*.png binary
*.jpg binary
*.jpeg binary
*.ttf binary
*.otf binary
*.wav binary
*.ogg binary
*.mp3 binary
*.zip binary
