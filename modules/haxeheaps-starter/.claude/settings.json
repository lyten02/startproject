{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/scripts/hook_post_edit.py\"",
            "timeout": 10,
            "statusMessage": "Checking god-file limit (200 LOC)"
          },
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/scripts/hook_lint.py\"",
            "async": true,
            "timeout": 120,
            "statusMessage": "Running lint in background"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/scripts/hook_notify.py\"",
            "async": true,
            "timeout": 5,
            "statusMessage": "Notifying OS: task complete"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/scripts/hook_notify.py\"",
            "async": true,
            "timeout": 5,
            "statusMessage": "Notifying OS: attention required"
          }
        ]
      }
    ]
  }
}
